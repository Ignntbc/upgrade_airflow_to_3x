# =============================================================================
# Окружение для docker-compose
# =============================================================================

# UID хоста, под которым будет работать airflow внутри контейнера
# (рекомендуется указать ваш UID: `id -u`)
AIRFLOW_UID=50000

# --- Postgres (метаданные Airflow) ----------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- RabbitMQ (брокер очереди Celery) -------------------------------------
RABBITMQ_USER=airflow
RABBITMQ_PASSWORD=airflow

# --- Airflow ---------------------------------------------------------------
# Сгенерировать новый ключ:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmRsa2pmZGxrYWpzZmRsa2phZGxma2FzamRmbGRrYWo=

# Секрет для веб-сервера (любая случайная строка)
AIRFLOW_WEBSERVER_SECRET_KEY=webserver_secret_key

# Учётка администратора Airflow UI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
